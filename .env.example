# Financial Agent 环境变量示例
# 复制为 .env 后填写你自己的值，不要把真实密钥提交到仓库

# 基础服务配置
PORT=8001
HOST=0.0.0.0

# Railway / 容器部署时建议保留默认值
# 健康检查地址：/healthz

# 可选：接口鉴权
# API_KEY=replace-with-your-api-key
# API_KEY_HEADER=X-API-Key

# 火山引擎 Ark / Coding Plan
# ARK_API_KEY=replace-with-your-ark-key
# ARK_MODEL=ark-code-latest
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
# 兼容旧变量名：
# VOLCENGINE_ARK_API_KEY=replace-with-your-ark-key
# VOLCENGINE_ARK_MODEL=ark-code-latest
# VOLCENGINE_ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3

# 数据源 API
# ALPHA_VANTAGE_API_KEY=replace-with-your-alpha-vantage-key
# FINNHUB_API_KEY=replace-with-your-finnhub-key
# FRED_API_KEY=replace-with-your-fred-key

# Alpaca 股票池主数据
# ALPACA_API_KEY_ID=replace-with-your-alpaca-key-id
# ALPACA_API_SECRET_KEY=replace-with-your-alpaca-secret
# ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Longbridge 备用数据
# LONGBRIDGE_APP_KEY=replace-with-your-longbridge-app-key
# LONGBRIDGE_APP_SECRET=replace-with-your-longbridge-app-secret
# LONGBRIDGE_ACCESS_TOKEN=replace-with-your-longbridge-access-token

# 可选：覆盖默认数据路径
# FINANCIAL_AGENT_DB_PATH=E:/Msc_project/Financial-agent/data/runtime/financial_agent_runs.sqlite3
# FINANCIAL_AGENT_MARKET_DB_PATH=E:/Msc_project/Financial-agent/data/runtime/financial_agent_market.sqlite3
# FINANCIAL_AGENT_UNIVERSE_CSV=E:/Msc_project/Financial-agent/data/seed/sp500_supabase_ready.csv

# Railway 持久化卷建议
# FINANCIAL_AGENT_DB_PATH=/app/data/financial_agent_runs.sqlite3
# FINANCIAL_AGENT_MARKET_DB_PATH=/app/data/financial_agent_market.sqlite3

# yfinance / Yahoo 路由（默认 auto：先直连，失败后代理重试）
# 若不填 MARKET_PROXY_URL，会自动尝试读取系统 HTTP_PROXY / HTTPS_PROXY
# MARKET_PROXY_MODE=auto
# MARKET_PROXY_URL=http://127.0.0.1:7890
# MARKET_NO_PROXY_HOSTS=query1.finance.yahoo.com,query2.finance.yahoo.com,finance.yahoo.com
